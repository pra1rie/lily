// hello world in lily!

var GLOBAL = "World";

fun double(number)
    return number * 2;
end

fun say_hello(name)
    write "Hello, ", name, "!\n";
    return "Bruh!\n";
end

fun main()
    var a = double(33) + 3;
    write say_hello(GLOBAL);
    if a == 69
        write "a == 69\n";
    else if a < 69
        write "a < 69\n";
    else
        write "a > 69\n";
    end
    var i = -1;
    while (i = i + 1) <= 5
        if (i == 4) break; end
        write i, '\n';
    end
end
